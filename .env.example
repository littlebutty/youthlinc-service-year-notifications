# Copy this file to .env and fill in your real keys.
# .env is gitignored — never commit it.

# Anthropic (Claude) — https://console.anthropic.com/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Unsplash — https://unsplash.com/developers (create an app, copy Access Key)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# GroupMe — https://dev.groupme.com → click your name → Access Token
# Needed to upload images to GroupMe's image CDN before posting
GROUPME_ACCESS_TOKEN=your_groupme_access_token_here
